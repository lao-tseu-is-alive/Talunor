# Talunor configuration — copy to `.env` and edit.
#
#   cp .env_sample .env
#
# Talunor auto-loads `.env` from the working directory at startup. Variables
# already set in your real environment take precedence over this file, so
# `TALUNOR_MODEL=... talunor` still wins. NEVER commit a real .env with secrets
# (it is git-ignored).

# ── Chat provider ────────────────────────────────────────────────────────────
# Which LLM backend answers. Embeddings always run locally (bundled model);
# only chat uses this provider.
#   ollama      — local Ollama server (default; free, private)
#   openrouter  — hosted frontier models via OpenRouter (OpenAI/Anthropic/…)
TALUNOR_PROVIDER=ollama

# Model for the selected provider. Leave unset to use the provider default.
#   ollama:     qwen3:latest (default), qwen2.5-coder:14b, …  (must be pulled)
#   openrouter: openai/gpt-4o-mini (default), anthropic/claude-sonnet-4,
#               openai/gpt-5, google/gemini-2.5-pro, …  (see openrouter.ai/models)
#TALUNOR_MODEL=qwen3:latest

# Reflection distils durable facts from each message into semantic memory, at the
# cost of a second model call per turn. Set to 0 to disable it — handy on a paid
# provider where every call costs money. Default: on.
#TALUNOR_REFLECT=1

# Tools (calculator, current_time, recall_memory) via native tool-calling. Set to
# 0 if your chat model does not support tools. Default: on.
#TALUNOR_TOOLS=1

# Action policy: a YAML rule file consulted before every tool call, deciding
# allow / prompt / deny per tool (see docs/policy.sample.yaml). Unset = the
# default policy, which preserves each tool's own approval behaviour (bash always
# prompts; web_fetch prompts unless the host is allowlisted). A malformed file
# fails closed at startup.
#TALUNOR_POLICY=./docs/policy.sample.yaml

# Planner (opt-in): plan before acting. When on, each turn produces an explicit,
# inspectable plan; you approve it; then the ReAct loop executes it, capped to the
# plan's tools (the model can't call a tool the plan didn't name). Off = the plain
# ReAct loop (tools discovered one call at a time). See /plan to view the last plan.
#TALUNOR_PLANNER=1
# How a plan is approved: plan = approve the whole plan once, then run its tools;
# step = approve the plan AND confirm each risky step; highrisk = no whole-plan
# prompt, the plan is advisory and per-call policy prompts as usual. Default: plan.
#TALUNOR_APPROVAL=plan

# Debug trace of the otherwise-invisible loop decisions: which memories were
# recalled (id + distance), which tools ran, and what reflection stored/skipped.
# Off by default. Values: 1 → a "talunor-debug.log" next to the DB (tail -f it,
# so the TUI screen stays clean); stderr → the terminal (handy with --plain);
# or a file path. The trace can include snippets of recalled memory content.
#TALUNOR_DEBUG=1

# ── Sandboxed bash tool (opt-in, approval-gated) ─────────────────────────────
# Give the agent a `bash` tool that runs shell commands in a throwaway sandbox
# with NO network and NO host filesystem access. Every call still needs your
# explicit y/N approval (the v0.8.0 gate). OFF by default — turn on with 1.
#TALUNOR_BASH=1

# Which sandbox backend runs those commands:
#   nerdctl     — a real OCI runtime (nerdctl or docker). The strong option;
#                 brings seccomp, cgroups, dropped caps. Needs Rancher Desktop /
#                 Docker running.
#   namespaces  — a from-scratch, rootless Linux user-namespace sandbox. Great
#                 for learning, but NOT a strong boundary (no seccomp). Linux
#                 only; needs unprivileged user namespaces enabled.
# Unset = auto-detect: use a container runtime if present, else namespaces.
#TALUNOR_SANDBOX=nerdctl

# nerdctl backend: the image scripts run in (small, pinned). Pulled on first use.
#TALUNOR_SANDBOX_IMAGE=alpine:3.20

# namespaces backend: point at an existing rootfs dir (must have /bin/sh), or a
# specific busybox binary to build a minimal rootfs from. Both optional — by
# default a static busybox on PATH is used and the rootfs is cached under
# $XDG_CACHE_HOME/talunor/sandbox-rootfs.
#TALUNOR_SANDBOX_ROOTFS=/path/to/rootfs
#TALUNOR_SANDBOX_BUSYBOX=/usr/bin/busybox

# ── web_fetch tool (opt-in, approval-gated) ──────────────────────────────────
# Let the agent read an http(s) URL and return it as text — the network opt-IN,
# mirror of the network-off bash tool. OFF by default. It refuses private/
# loopback/link-local/cloud-metadata addresses (SSRF guard), caps the body, and
# asks for your y/N on each call. Turn on with 1.
#TALUNOR_WEBFETCH=1
# Hosts that skip the approval prompt (comma-separated). Exact host, or a leading
# dot for sub-domains (".example.com" matches docs.example.com). The SSRF guard
# still applies to allowlisted hosts.
#TALUNOR_WEBFETCH_ALLOW=example.com,.trusted.org
# Body cap in bytes (default 524288 = 512 KiB) and request timeout (default 10s).
#TALUNOR_WEBFETCH_MAX_BYTES=524288
#TALUNOR_WEBFETCH_TIMEOUT=10s

# ── Ollama (when TALUNOR_PROVIDER=ollama) ────────────────────────────────────
# OpenAI-compatible base URL of your Ollama server.
#TALUNOR_OLLAMA_URL=http://localhost:11434/v1

# ── OpenRouter (when TALUNOR_PROVIDER=openrouter) ────────────────────────────
# Required for openrouter. Get one at https://openrouter.ai/keys.
#OPENROUTER_API_KEY=sk-or-v1-...your-key...
# Override the API base URL (rarely needed).
#TALUNOR_OPENROUTER_URL=https://openrouter.ai/api/v1

# ── Storage & assets ─────────────────────────────────────────────────────────
# Long-term memory database file. Default: $XDG_DATA_HOME/talunor/talunor.db
# (or ~/.local/share/talunor/talunor.db), created automatically.
#TALUNOR_DB=/home/you/.local/share/talunor/talunor.db

# Paths to the loadable SQLite extensions and the GGUF embedding model. Defaults
# point under ext/ (fetched by `make deps`); the container image sets these to
# its baked-in copies. Note: no ".so" suffix on the extension paths.
#TALUNOR_VECTOR_EXT=ext/vector
#TALUNOR_AI_EXT=ext/ai
#TALUNOR_EMBED_MODEL=ext/models/all-MiniLM-L6-v2.f16.gguf

# ── Note: OLLAMA_HOST is an *Ollama* setting, not Talunor's ──────────────────
# It controls what address the Ollama server binds. Do NOT set it to 0.0.0.0 just
# to reach Ollama from a container — see docs/ollama-networking.md for a safer
# loopback + firewall bridge.
